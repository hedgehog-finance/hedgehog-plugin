{
  "name": "@hedgehog-finance/hedgehog-plugin",
  "version": "1.0.41",
  "description": "Hedgehog App WebSocket channel and Watchlist Tools for OpenClaw",
  "keywords": [
    "bot",
    "channel",
    "clawdbot",
    "openclaw",
    "stream",
    "hedgehog-app"
  ],
  "repository": "github:hedgehog-finance/hedgehog-plugin",
  "main": "dist/index.js",
  "type": "module",
  "author": "Hedgehog Finance",
  "license": "MIT",
  "files": [
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "index.ts",
    "setup-api.ts",
    "src/**/*.ts",
    "openclaw.plugin.json",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.66.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.1.0",
    "ws": "^8.20.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  },
  "openclaw": {
    "kind": "channel",
    "contracts": {
      "tools": [
        "get_watchlist",
        "get_industry_list",
        "dispatch_daily_morning_briefing",
        "save_daily_morning_briefing",
        "save_stock_ai_analysis",
        "save_information_verification",
        "save_article_deep_reasoning_analysis",
        "get_stock_basic_info",
        "get_stock_note",
        "update_hedgehog_skill_versions"
      ]
    },
    "extensions": [
      "./index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "setupEntry": "./dist/setup-api.js",
    "install": {
      "npmSpec": "@hedgehog-finance/hedgehog-plugin@latest",
      "defaultChoice": "npm"
    },
    "compat": {
      "pluginApi": ">=2026.5.12",
      "minGatewayVersion": "2026.5.12"
    },
    "build": {
      "openclawVersion": "2026.5.12",
      "pluginSdkVersion": "2026.5.12"
    }
  }
}